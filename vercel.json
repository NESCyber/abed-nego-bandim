{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/frontend/pages/index.html" },
    { "source": "/index.html", "destination": "/frontend/pages/index.html" },
    { "source": "/css/:path*", "destination": "/frontend/css/:path*" },
    { "source": "/js/:path*", "destination": "/frontend/js/:path*" },
    { "source": "/pages/:path*", "destination": "/frontend/pages/:path*" },
    { "source": "/:page.html", "destination": "/frontend/pages/:page.html" }
  ]
}
